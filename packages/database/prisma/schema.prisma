generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, uuid_ossp]
}

enum FileType {
  FILE
  FOLDER
}

enum StorageProvider {
  TELEGRAM
}

enum SharePermission {
  VIEW
  DOWNLOAD
  EDIT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  UPLOAD
  THUMBNAIL
  METADATA_EXTRACTION
  VIDEO_PROCESSING
  CLEANUP
  SHARE_EXPIRATION
  VIRUS_SCAN
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  telegramId     BigInt    @unique
  phoneNumber    String?
  firstName      String?
  lastName       String?
  username       String?
  avatarUrl      String?
  email          String?
  isActive       Boolean   @default(true)
  isPremium      Boolean   @default(false)
  storageUsed    BigInt    @default(0)
  storageLimit   BigInt    @default(5368709120)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions    TelegramSession[]
  sessionsJwt JwtSession[]
  files       File[]
  folders     Folder[]
  shares      Share[]
  activityLogs ActivityLog[]
  uploadJobs  UploadJob[]
  thumbnails  Thumbnail[]

  @@index([telegramId])
  @@index([username])
  @@map("users")
}

model TelegramSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  encryptedSession String  @db.Text
  sessionId      String   @unique
  deviceInfo     String?  @db.Text
  ipAddress      String?
  isActive       Boolean  @default(true)
  lastUsedAt     DateTime @default(now())
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("telegram_sessions")
}

model JwtSession {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  refreshToken  String   @unique
  deviceInfo    String?  @db.Text
  ipAddress     String?
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime @default(now())
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("jwt_sessions")
}

model Folder {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  parentId    String?  @db.Uuid
  name        String
  path        String   @db.Text
  icon        String?
  color       String?
  isStarred   Boolean  @default(false)
  isTrashed   Boolean  @default(false)
  trashedAt   DateTime?
  fileCount   Int      @default(0)
  totalSize   BigInt   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[] @relation("FolderTree")
  files    File[]

  @@unique([userId, parentId, name])
  @@index([userId, parentId])
  @@index([userId, isStarred])
  @@index([userId, isTrashed])
  @@index([name])
  @@map("folders")
}

model File {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  folderId        String?  @db.Uuid
  name            String
  originalName    String
  mimeType        String
  extension       String
  size            BigInt
  hash            String   @db.Text
  hashAlgorithm   String   @default("sha256")
  telegramMessageId Int?
  telegramChannelId BigInt?
  telegramFileReference String? @db.Text
  storageProvider StorageProvider @default(TELEGRAM)
  storagePath     String?  @db.Text
  encryptionKey   String?  @db.Text
  encryptionIv    String?  @db.Text
  isEncrypted     Boolean  @default(false)
  isStarred       Boolean  @default(false)
  isTrashed       Boolean  @default(false)
  trashedAt       DateTime?
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  version         Int      @default(1)
  parentVersionId String?  @db.Uuid
  metadata        Json?    @db.JsonB
  width           Int?
  height          Int?
  duration        Int?
  description     String?  @db.Text
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder       Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  thumbnail    Thumbnail?
  activityLogs ActivityLog[]

  @@unique([userId, folderId, name])
  @@index([userId, folderId])
  @@index([userId, isStarred])
  @@index([userId, isTrashed])
  @@index([userId, mimeType])
  @@index([name])
  @@index([hash])
  @@index([createdAt])
  @@index([telegramMessageId])
  @@index([telegramChannelId])
  @@map("files")
}

model Thumbnail {
  id        String   @id @default(uuid()) @db.Uuid
  fileId    String   @unique @db.Uuid
  userId    String   @db.Uuid
  data      Bytes    @db.ByteA
  mimeType  String   @default("image/webp")
  width     Int
  height    Int
  size      Int
  createdAt DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@map("thumbnails")
}

model Share {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  fileId        String?  @db.Uuid
  folderId      String?  @db.Uuid
  token         String   @unique
  permission    SharePermission @default(VIEW)
  password      String?  @db.Text
  maxDownloads  Int?
  downloadCount Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  file   File?   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([fileId])
  @@index([folderId])
  @@index([expiresAt])
  @@map("shares")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  fileId      String?  @db.Uuid
  action      String
  details     Json?    @db.JsonB
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  file File? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, action])
  @@index([fileId])
  @@index([createdAt])
  @@map("activity_logs")
}

model UploadJob {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  fileId        String?   @db.Uuid
  fileName      String
  fileSize      BigInt
  mimeType      String
  folderId      String?   @db.Uuid
  status        JobStatus @default(PENDING)
  progress      Int       @default(0)
  chunkSize     Int       @default(524288)
  totalChunks   Int       @default(0)
  uploadedChunks Int      @default(0)
  errorMessage  String?   @db.Text
  metadata      Json?     @db.JsonB
  retryCount    Int       @default(0)
  maxRetries    Int       @default(5)
  nextRetryAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks   UploadChunk[]

  @@index([userId, status])
  @@index([status])
  @@index([createdAt])
  @@map("upload_jobs")
}

model UploadChunk {
  id          String   @id @default(uuid()) @db.Uuid
  jobId       String   @db.Uuid
  chunkIndex  Int
  chunkSize   Int
  checksum    String   @db.Text
  data        Bytes    @db.ByteA
  createdAt   DateTime @default(now())

  job UploadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, chunkIndex])
  @@index([jobId])
  @@map("upload_chunks")
}

model BackgroundJob {
  id          String    @id @default(uuid()) @db.Uuid
  type        JobType
  payload     Json      @db.JsonB
  status      JobStatus @default(PENDING)
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  errorMessage String?  @db.Text
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type, status])
  @@index([status, priority])
  @@index([scheduledAt])
  @@map("background_jobs")
}

model StorageAnalytics {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  totalFiles  Int      @default(0)
  totalFolders Int     @default(0)
  totalSize   BigInt   @default(0)
  fileTypeDistribution Json? @db.JsonB
  dailyUpload  BigInt  @default(0)
  dailyDownload BigInt @default(0)
  recordedAt  DateTime @default(now())

  @@index([userId])
  @@index([recordedAt])
  @@map("storage_analytics")
}
