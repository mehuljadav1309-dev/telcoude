# Telegram Drive - Environment Variables
# Copy this to .env and fill in your values

# App
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_drive
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=telegram-drive

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=telegram-drive

# Encryption
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_IV=0123456789abcdef

# Telegram API (Get from https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_DIR=./data/sessions
TELEGRAM_MAX_FILE_SIZE=2097152000

# BullMQ
BULLMQ_CONCURRENCY=5
BULLMQ_RETRY_DELAY=5000
BULLMQ_MAX_RETRIES=5

# Upload
UPLOAD_MAX_FILE_SIZE=2097152000
UPLOAD_CHUNK_SIZE=524288
UPLOAD_TEMP_DIR=./data/uploads
UPLOAD_PARALLEL_CHUNKS=3

# Thumbnail
THUMBNAIL_WIDTH=320
THUMBNAIL_HEIGHT=320
THUMBNAIL_QUALITY=80

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Sentry
SENTRY_DSN=

# Storage
STORAGE_MAX_PER_USER=5368709120
STORAGE_WARNING_THRESHOLD=0.9

# Share
SHARE_DEFAULT_EXPIRY_DAYS=7
SHARE_MAX_EXPIRY_DAYS=365
